rules_version = '2';

// Multi-tenant: korisnik može biti član više firmi (kompanijeIds) i vidi podatke svih svojih firmi.
service cloud.firestore {
  match /databases/{database}/documents {

    function prijavljen() {
      return request.auth != null;
    }

    function korisnikDoc() {
      return get(/databases/$(database)/documents/korisnici/$(request.auth.uid)).data;
    }

    // Firme kojima korisnik pripada (podržava i stari format sa jednim kompanijaId).
    function mojeKompanije() {
      return korisnikDoc().get('kompanijeIds', [korisnikDoc().get('kompanijaId', '')]);
    }

    function pripada(podaci) {
      return prijavljen() && (podaci.kompanijaId in mojeKompanije());
    }

    // Profil korisnika — svako vidi i menja samo svoj.
    match /korisnici/{uid} {
      allow read, create, update: if prijavljen() && request.auth.uid == uid;
    }

    // Kompanije — spisak je čitljiv (za registraciju i prebacivanje), izmene samo za svoje firme.
    match /kompanije/{id} {
      allow read, create: if prijavljen();
      allow update, delete: if prijavljen() && (id in mojeKompanije());
    }

    // Tenant kolekcije — pristup isključivo podacima firmi kojima korisnik pripada.
    match /laboratorije/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /zaposleni/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /podloge/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /uzorci/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /zasejavanja/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /analize/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
  }
}
