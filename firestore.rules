rules_version = '2';

// Multi-tenant sa kontrolisanim pristupom:
// - izvor istine o pripadnosti je kolekcija `clanstva/{kompanijaId__uid}` (piše je osnivač ili admin),
// - korisnik NE može sam sebi da doda firmu (za razliku od ranijeg modela preko profila),
// - firme se ne mogu izlistati; pridruživanje ide preko koda + zahteva koji admin odobrava.
service cloud.firestore {
  match /databases/{database}/documents {

    function prijavljen() {
      return request.auth != null;
    }

    function ja() {
      return request.auth.uid;
    }

    function clanstvoPut(kid) {
      return /databases/$(database)/documents/clanstva/$(kid + '__' + ja());
    }

    function jeClan(kid) {
      return prijavljen() && exists(clanstvoPut(kid));
    }

    function jeAdmin(kid) {
      return jeClan(kid) && get(clanstvoPut(kid)).data.uloga == 'admin';
    }

    function osnivac(kid) {
      return get(/databases/$(database)/documents/kompanije/$(kid)).data.osnivacUid == ja();
    }

    function pripada(podaci) {
      return jeClan(podaci.kompanijaId);
    }

    // Profil — svako samo svoj. Nema više uticaj na pristup podacima (samo lični podaci + aktivna firma).
    match /korisnici/{uid} {
      allow read, create, update: if prijavljen() && ja() == uid;
    }

    // Firme — čita samo član (get, nema listanja). Kreira svaki prijavljen (postaje osnivač).
    match /kompanije/{id} {
      allow get: if jeClan(id);
      allow create: if prijavljen() && request.resource.data.osnivacUid == ja();
      allow update, delete: if jeAdmin(id);
    }

    // Kod -> firma. Get samo ako se zna tačan kod (id). Upisuje samo osnivač te firme.
    match /kompanije_kodovi/{kod} {
      allow get: if prijavljen();
      allow create: if prijavljen() && osnivac(request.resource.data.kompanijaId);
    }

    // Članstva — izvor istine o pripadnosti firmama.
    match /clanstva/{cid} {
      allow read: if prijavljen()
        && (resource == null || resource.data.uid == ja() || jeAdmin(resource.data.kompanijaId));
      // Osnivač sam sebi dodeljuje admin; admin dodeljuje druge korisnike.
      allow create: if prijavljen() && (
        (request.resource.data.uid == ja()
          && request.resource.data.uloga == 'admin'
          && osnivac(request.resource.data.kompanijaId))
        || jeAdmin(request.resource.data.kompanijaId)
      );
      allow delete: if prijavljen()
        && (resource.data.uid == ja() || jeAdmin(resource.data.kompanijaId));
    }

    // Zahtevi za pristup — podnosilac kreira svoj; admin firme čita i odobrava/odbija.
    match /zahtevi/{zid} {
      allow read: if prijavljen()
        && (resource == null || resource.data.uid == ja() || jeAdmin(resource.data.kompanijaId));
      allow create: if prijavljen()
        && request.resource.data.uid == ja()
        && request.resource.data.status == 'na_cekanju';
      allow delete: if prijavljen()
        && (resource.data.uid == ja() || jeAdmin(resource.data.kompanijaId));
    }

    // Tenant kolekcije — pristup isključivo članovima firme (provera exists nad clanstvima).
    match /laboratorije/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /zaposleni/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /podloge/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /uzorci/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /zasejavanja/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
    match /analize/{id} {
      allow read, update, delete: if pripada(resource.data);
      allow create: if pripada(request.resource.data);
    }
  }
}
